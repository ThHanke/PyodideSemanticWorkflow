@base <https://thhanke.github.io/PyodideSemanticWorkflow/> .
@prefix : <http://example.com/> .
@prefix spw: <https://thhanke.github.io/PyodideSemanticWorkflow#> .
@prefix p-plan: <http://purl.org/net/p-plan#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix unit: <http://qudt.org/vocab/unit/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

################################################################################
# EXECUTION INSTANCE — Sum Workflow Run
#
# Template level (spw:) stays in urn:vg:workflows.
# Run level (:) lives in urn:vg:data.
################################################################################


################################################################################
# INPUT ENTITIES (run-scoped, default namespace)
################################################################################

:SumInput1_1748000000000 a p-plan:Entity, prov:Entity, qudt:QuantityValue ;
    rdfs:label "Input Length 1" ;
    qudt:numericValue "2.0"^^xsd:decimal ;
    qudt:unit unit:MilliM ;
    p-plan:correspondsToVariable spw:SumInput1 .

:SumInput2_1748000000000 a p-plan:Entity, prov:Entity, qudt:QuantityValue ;
    rdfs:label "Input Length 2" ;
    qudt:numericValue "3.0"^^xsd:decimal ;
    qudt:unit unit:MilliM ;
    p-plan:correspondsToVariable spw:SumInput2 .


################################################################################
# ACTIVITY (run-scoped, default namespace)
################################################################################

:SumQuantitiesRun_1748000000000 a prov:Activity, p-plan:Activity ;
    rdfs:label "Sum QUDT Quantities Run" ;
    p-plan:correspondsToStep spw:SumStep ;
    prov:hadPlan spw:SumTemplate ;
    prov:used :SumInput1_1748000000000, :SumInput2_1748000000000 ;
    prov:used spw:SumCode, spw:SumRequirements ;
    prov:wasAssociatedWith spw:PyodideEngine ;
    prov:startedAtTime "2026-01-30T10:45:00Z"^^xsd:dateTime ;
    prov:endedAtTime "2026-01-30T10:45:01Z"^^xsd:dateTime .


################################################################################
# OUTPUT ENTITY (run-scoped, default namespace)
################################################################################

:SumOutput_1748000000000 a p-plan:Entity, prov:Entity, qudt:QuantityValue ;
    rdfs:label "Sum Result" ;
    qudt:numericValue "5.0"^^xsd:decimal ;
    qudt:unit unit:MilliM ;
    p-plan:correspondsToVariable spw:SumOutput ;
    prov:wasGeneratedBy :SumQuantitiesRun_1748000000000 ;
    prov:wasDerivedFrom :SumInput1_1748000000000, :SumInput2_1748000000000 .
